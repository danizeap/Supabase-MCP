{
  "name": "supabase-storage-mcp",
  "version": "1.0.0",
  "description": "Local stdio MCP server exposing Supabase Storage operations (buckets, uploads, shareable links). Additive-only, storage-only.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "bin": {
    "supabase-storage-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "mcp",
    ".claude-plugin",
    "skills",
    ".env.example",
    "README.md"
  ],
  "scripts": {
