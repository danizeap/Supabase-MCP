# Supabase Storage plugin — credentials
# Copy this file to ".env" (same folder) and fill in real values.
# The .env file is gitignored and must NEVER be committed or shared.

# Your Supabase project URL.
# Find it in the Supabase dashboard: Project Settings -> Data API -> Project URL
# Example: https://abcdefghijklmno.supabase.co
SUPABASE_URL=

# Service role key (SENSITIVE — treat like a password).
# Find it in the Supabase dashboard: Project Settings -> API Keys -> service_role (reveal).
# This key can access your whole project, so keep it secret. This plugin only ever uses it
# for Storage operations and exposes no database tools.
SUPABASE_SERVICE_ROLE_KEY=
